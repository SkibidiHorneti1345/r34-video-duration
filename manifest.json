{
  "manifest_version": 3,
  "name": "Rule34.xxx Video Duration",
  "version": "1.0",
  "description": "Smoothly displays video duration on thumbnails for rule34.xxx like YouTube.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.rule34.xxx/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.rule34.xxx/*", "*://rule34.xxx/*"],
      "css": ["style.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
