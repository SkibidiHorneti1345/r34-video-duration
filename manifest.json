{
  "manifest_version": 3,
  "name": "Rule34.xxx Video Duration",
  "version": "2.0.0",
  "description": "Displays video durations and GIF badges on rule34.xxx thumbnails.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.rule34.xxx/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.rule34.xxx/*", "*://rule34.xxx/*"],
      "css": ["style.css"],
      "js": ["src/core.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
